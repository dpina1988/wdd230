/* Imports */
@import url('https://fonts.googleapis.com/css2?family=Lato&family=Noto+Serif&display=swap');

/*
* {
    border: 2px solid blue;
}
*/

a {
    padding-bottom: 5px;
}

footer {
    background-color: #219ebc;
    color: #FFFF;
    border-radius: 25px;
    width: 90%;
    margin: 5px auto;
}

footer div {
    color: #FFFF;
    margin: 0 auto;
    align-content: center;
    justify-items: center;
    padding: 5px 0;
}

h1,
h2,
h3,
h4 {
    margin: 0 auto;
}

h3 {
    color: #FFFF;
    background-color: #219ebc;
    border-radius: 30px 30px 0 0;
}

header {
    background-color: #219ebc;
    color: #FFFF;
    width: 90%;
    margin: 10px auto 10px;
    text-align: center;
    border-radius: 10PX;
    border: 5px solid #daa520;
}

img {
    max-width: 300px;
    margin: 0 auto;
}

main {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    width: 90%;
    margin: auto;
}

main div {
    display: grid;
    width: 90%;
    margin: 5px auto;
    text-align: center;
    border-radius: 25px;
    border: 1px solid #daa520;
}

p {
    padding: 0 5px;
}